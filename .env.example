PORT=3000

# These match docker-compose.yml's non-default host ports (5442/9192), chosen so this
# repo's local stack doesn't collide with the shared ecommerce-infra Postgres/Kafka
# containers if they're also running (which default to 5432/9092).
DB_HOST=localhost
DB_PORT=5442
DB_USERNAME=orders
DB_PASSWORD=orders
DB_NAME=orders

KAFKA_BROKERS=localhost:9192
KAFKA_CLIENT_ID=ecommerce-orders
KAFKA_GROUP_ID=ecommerce-orders-consumer
